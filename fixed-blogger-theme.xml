<b:skin><![CDATA[
/* ================================================
   CATATAN GURU IPS — V4 PREMIUM EDITION (SYNCED)
   Design: Modern Clean Editorial (No Black)
   Color Theme: White, Cyan, Slate
   Status: Stable Fix for XML Parsing
================================================ */

:root {
  --primary: #0891b2; /* cyan-600 */
  --primary-light: #ecfeff;
  --secondary: #6366f1; /* indigo-600 */
  --accent: #f43f5e; /* rose-600 */
  --gradient-brand: linear-gradient(135deg, #0891b2 0%, #6366f1 100%);
  
  --bg-primary: #f8fafc; /* slate-50 */
  --bg-secondary: #ffffff;
  --bg-card: #ffffff;
  --text-primary: #0f172a; /* slate-900 */
  --text-secondary: #475569; /* slate-600 */
  --text-muted: #94a3b8;
  
  --border: #e2e8f0;
  --radius-xl: 32px;
  --radius-2xl: 48px;
  --shadow-card: 0 4px 20px rgba(0,0,0,0.05);
  --header-h: 80px;
}

body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg-primary); color: var(--text-primary); margin: 0; }
a { text-decoration: none; transition: 0.3s; }

#site-header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  height: var(--header-h); background: rgba(255,255,255,0.8);
  backdrop-filter: blur(16px); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; padding: 0 40px;
}

.logo-text { font-weight: 900; font-size: 1.25rem; letter-spacing: -1px; background: var(--gradient-brand); -webkit-background-clip: text; -webkit-fill-color: transparent; background-clip: text; color: transparent; }

.hero-section { padding: 160px 40px 80px; text-align: center; }
.hero-title { font-size: 4rem; font-weight: 900; letter-spacing: -3px; line-height: 0.9; margin-bottom: 24px; }
.hero-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; max-width: 1200px; margin: 60px auto; }

.card { background: white; border-radius: var(--radius-xl); padding: 40px; border: 1px solid var(--border); transition: 0.3s; text-align: left; }
.card:hover { transform: translateY(-10px); border-color: var(--primary); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
.card.featured { background: var(--gradient-brand); color: white; border: none; }
.card.featured h3, .card.featured p { color: white; }

.ai-feed-section { background: white; border-radius: var(--radius-2xl); border: 1px solid var(--border); margin: 0 40px 100px; padding: 80px; box-shadow: var(--shadow-card); }

.post-card { background: white; border-radius: var(--radius-xl); border: 1px solid var(--border); margin-bottom: 40px; overflow: hidden; }
.post-card-content { padding: 32px; }

.footer-social-link {
  width: 44px; height: 44px; border-radius: 12px; background: #f1f5f9;
  display: flex; align-items: center; justify-content: center; color: #94a3b8;
  transition: all 0.2s;
}
.footer-social-link:hover.fb { color: #1877F2; background: #eff6ff; }
.footer-social-link:hover.tw { color: #1DA1F2; background: #f0f9ff; }
.footer-social-link:hover.ig { color: #E4405F; background: #fdf2f8; }
.footer-social-link:hover.yt { color: #FF0000; background: #fef2f2; }
.footer-social-link:hover.wa { color: #25D366; background: #f0fdf4; }

]]></b:skin>
</head>
<body>

<header id='site-header'>
  <a class='logo-text' expr:href='data:blog.homepageUrl'>CATATAN GURU IPS</a>
  <div class='nav-links' style='display: flex; gap: 24px; font-weight: 700; font-size: 14px;'>
    <a href='/' style='color: var(--text-primary);'>Beranda</a>
    <a href='/search/label/Perangkat' style='color: var(--text-secondary);'>Perangkat</a>
    <a href='/search/label/HOTS' style='color: var(--text-secondary);'>Bank Soal</a>
    <a href='/search/label/EdTech' style='color: var(--text-secondary);'>EdTech</a>
  </div>
</header>

<b:if cond='data:view.isHomepage'>
  <section class='hero-section'>
    <h1 class='hero-title'>Digital <span style='color: var(--primary);'>Resources</span> for Social Science.</h1>
    <p style='font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;'>Platform futuristik untuk guru modern: menyederhanakan administrasi dengan AI.</p>
    
    <div class='hero-grid'>
      <div class='card'>
        <div style='width: 50px; height: 50px; background: #ecfeff; color: var(--primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;'><i class='fas fa-book-open fa-lg'/></div>
        <h3>Perangkat Ajar</h3>
